# LLM Provider Configuration
# Options: openrouter
LLM_PROVIDER=openrouter

# OpenRouter API Key (required if using openrouter provider)
# Get your key from https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenRouter Model (optional, defaults to deepseek/deepseek-chat-v3-0324)
OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324

# LLM Generation Parameters
TEMPERATURE=0.3
MAX_OUTPUT_TOKENS=1024
LLM_TIMEOUT=30

# Enable/disable memory extraction (set to false to save API quota)
MEMORY_EXTRACTION_ENABLED=false

# Google OAuth2 Credentials (optional, for Gmail/Drive/Calendar sync)
# Get these from https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# Session Secret Key (for secure OAuth2 flow, generate a long random string)
SESSION_SECRET_KEY=your-secret-key-change-in-production

# Upload directory (optional, defaults to ./uploads)
UPLOAD_DIR=./uploads
